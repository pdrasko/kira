{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "git -C /home/user/kira config user.email noreply@anthropic.com && git -C /home/user/kira config user.name Claude",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/user/kira/.claude/hooks/bump-version.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
